<WikiLayout title="LunaTech Bedrock Wiki">
    <section class="intro">
        <p>LunaTech Bedrock Wiki</p>
        <WikiSearch />
    </section>

    <section>
        <h2>Items ({itemsWithRecipes.length})</h2>
        <div class="grid">
            {
                itemsWithRecipes.map((item) => (
                    <div class="card" data-identifier={item.identifier}>
                        <div class="card-image">
                            {item.texturePath ? (
                                <img
                                    src={"/" + item.texturePath}
                                    alt={item.name}
                                    width="64"
                                    height="64"
                                />
                            ) : (
                                <div class="placeholder">No texture</div>
                            )}
                        </div>
                        <div class="card-content">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <h3>{item.name}</h3>
                                {item.notImplemented && (
                                    <span class="warning-badge">
                                        Not Implemented
                                    </span>
                                )}
                            </div>
                            <p class="identifier">{item.identifier}</p>
                            <p class="description">{item.description}</p>
                            {item.specs && (
                                <div class="specs">
                                    <details>
                                        <summary>Technical Specs</summary>
                                        <dl class="specs-list">
                                            {Object.entries(item.specs).map(
                                                ([key, value]) => (
                                                    <>
                                                        <dt>{key}</dt>
                                                        <dd>
                                                            {typeof value ===
                                                            "object"
                                                                ? JSON.stringify(
                                                                      value,
                                                                  )
                                                                : String(value)}
                                                        </dd>
                                                    </>
                                                ),
                                            )}
                                        </dl>
                                    </details>
                                </div>
                            )}
                            {item.lore && (
                                <div class="lore">
                                    <details>
                                        <summary>Lore</summary>
                                        <p>{item.lore}</p>
                                    </details>
                                </div>
                            )}
                            {item.recipes.length > 0 && (
                                <div class="recipes">
                                    <div class="recipe-grids">
                                        {item.recipes.map((recipePath) => {
                                            const recipe =
                                                getShapedRecipe(recipePath);
                                            if (!recipe) return null;
                                            return (
                                                <RecipeRenderer
                                                    recipe={recipe}
                                                    items={itemsWithRecipes}
                                                    blocks={blocksWithRecipes}
                                                    geometryPaths={
                                                        blockGeometryPathMap
                                                    }
                                                />
                                            );
                                        })}
                                    </div>
                                </div>
                            )}
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <section>
        <h2>Blocks ({blocksWithRecipes.length})</h2>
        <div class="grid">
            {
