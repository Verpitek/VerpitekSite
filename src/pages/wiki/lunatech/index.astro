// Apply auto-discovered recipes to items and blocks
const itemsWithRecipes = applyRecipesToItems(items);
const blocksWithRecipes = applyRecipesToItems(blocks);

const blockGeometryMap: Record<string, string> = {
    "lunatech:quarry_beam": "geometry.quarry_beam",
    "lunatech:item_extractor": "geometry.item_emitter",
    "lunatech:resin_jungle_log": "minecraft:geometry.full_block",
    "lunatech:quarry_controller": "geometry.quarry_controller",
    "lunatech:block_breaker": "geometry.block_breaker",
    "lunatech:recycler": "geometry.stiched_full_block",
    "lunatech:solid_fuel_generator": "geometry.stiched_full_block",
    "lunatech:power_node": "geometry.stiched_full_block",
    "lunatech:solar_panel": "geometry.stiched_full_block",
    "lunatech:accumulator": "geometry.stiched_full_block",
    "lunatech:electric_furnace": "geometry.stiched_full_block",
    "lunatech:windmill": "geometry.stiched_full_block",
    "lunatech:watermill": "geometry.stiched_full_block",
    "lunatech:terminal": "geometry.stiched_full_block",
    "lunatech:compressor": "geometry.stiched_full_block",
    "lunatech:macerator": "geometry.stiched_full_block",
    "lunatech:machine_block": "geometry.machine_block",
    "lunatech:microcontroller": "geometry.microcontroller",
    "lunatech:item_reciever": "geometry.item_reciever",
    "lunatech:quarry_corner": "geometry.quarry_corner",
    "lunatech:item_junction": "geometry.item_junction",
    "lunatech:wireless_charger": "geometry.stiched_full_block",
    "lunatech:analog_redstone_block": "geometry.invisible",
    "lunatech:composite_plate_grate": "geometry.alloy_plating",
    "lunatech:composite_scrap_plate_block": "geometry.alloy_plating",
    "lunatech:composite_frame_glass": "geometry.alloy_plating",
    "lunatech:composite_plate_block": "geometry.alloy_plating",
    "lunatech:composite_plate_ornament": "geometry.alloy_plating",
    "lunatech:composite_open_plate_grate": "geometry.alloy_plating",
    "lunatech:composite_plate_shingles": "geometry.alloy_plating",
    "lunatech:sturdy_composite_block": "geometry.alloy_plating",
    "lunatech:composite_path_block": "geometry.alloy_plating",
};

// Load geometries (used for model rendering)
const geometryData: Record<string, any> = {};
const geometryPaths = new Set<string>();
for (const block of blocksWithRecipes) {
    const geomId =
        blockGeometryMap[block.identifier] ||
        `geometry.${block.identifier.split(":")[1]}`;
    const path =
        geomId === "minecraft:geometry.full_block"
            ? "/LunaTech_RP/models/blocks/stitched_full_block.geo.json"
            : geometryMap[geomId] ||
              `/LunaTech_RP/models/blocks/${geomId.replace("geometry.", "")}.geo.json`;
    geometryPaths.add(path);
}

for (const path of geometryPaths) {
    try {
        const response = await fetch(path);
        if (response.ok) geometryData[path] = await response.json();
    } catch (e) {
        console.warn(`Failed to load geometry ${path}:`, e);
    }
}

function getShapedRecipe(path: string) {
    const data = recipeData[path];
    if (!data) return null;
    return parseRecipeJSON(data);
}

function getGeometryJson(geometry: string): any {
    const path =
        geometry === "minecraft:geometry.full_block"
            ? "/LunaTech_RP/models/blocks/stitched_full_block.geo.json"
            : geometryMap[geometry] ||
              `/LunaTech_RP/models/blocks/${geometry.replace("geometry.", "")}.geo.json`;
    return (
        geometryData[path] || {
            "minecraft:geometry": [
                {
                    description: {
                        identifier: "fallback",
                        texture_width: 16,
                        texture_height: 16,
                    },
                    bones: [],
                },
            ],
        }
    );
}

function getGeometryPath(identifier: string): string {
    const geomId =
        blockGeometryMap[identifier] || `geometry.${identifier.split(":")[1]}`;
    return geomId === "minecraft:geometry.full_block"
        ? "/LunaTech_RP/models/blocks/stitched_full_block.geo.json"
        : geometryMap[geomId] ||
              `/LunaTech_RP/models/blocks/${geomId.replace("geometry.", "")}.geo.json`;
}

// Map of block identifier → geometry file path, used by recipe item slots
const blockGeometryPathMap: Record<string, string> = {};
for (const block of blocksWithRecipes) {
    blockGeometryPathMap[block.identifier] = getGeometryPath(block.identifier);
}
