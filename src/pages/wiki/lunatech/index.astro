import { parseRecipeJSON } from "../../../lib/recipes/parsers";

// Global recipe data cache
const recipeData: Record<string, any> = {};

// Use import.meta.glob to load all recipe files
const allCraftingRecipeModules = import.meta.glob<{ default: any }>(
    "../../../../public/LunaTech_BP/recipes/crafting/*.json",
    { eager: true },
);
const allSmeltingRecipeModules = import.meta.glob<{ default: any }>(
    "../../../../public/LunaTech_BP/recipes/smelting/*.json",
    { eager: true },
);

// Build recipe map and populate recipeData cache
const recipesByOutput: Record<string, string[]> = {};

// Process crafting recipes
for (const [filePath, mod] of Object.entries(allCraftingRecipeModules)) {
    const recipeJson = mod.default;
    let recipeType = "";
    let recipeDataItem: any = null;

    if (recipeJson["minecraft:recipe_shaped"]) {
        recipeType = "minecraft:recipe_shaped";
        recipeDataItem = recipeJson["minecraft:recipe_shaped"];
    } else if (recipeJson["minecraft:recipe_shapeless"]) {
        recipeType = "minecraft:recipe_shapeless";
        recipeDataItem = recipeJson["minecraft:recipe_shapeless"];
    }

    if (recipeDataItem && recipeDataItem.result) {
        let outputItem = "";
        if (typeof recipeDataItem.result === "string") {
            outputItem = recipeDataItem.result;
        } else if (Array.isArray(recipeDataItem.result)) {
            outputItem = recipeDataItem.result[0]?.item || "";
        } else if (recipeDataItem.result.item) {
            outputItem = recipeDataItem.result.item;
        }

        if (outputItem) {
            const recipePath = `/LunaTech_BP/recipes/crafting/${filePath.split("/").pop()}`;
            recipeData[recipePath] = recipeJson;

            if (!recipesByOutput[outputItem]) {
                recipesByOutput[outputItem] = [];
            }
            recipesByOutput[outputItem].push(recipePath);
        }
    }
}

// Process smelting recipes
for (const [filePath, mod] of Object.entries(allSmeltingRecipeModules)) {
    const recipeJson = mod.default;
    if (recipeJson["minecraft:recipe_furnace"]) {
        const furnaceData = recipeJson["minecraft:recipe_furnace"];
        let outputItem = "";
        if (typeof furnaceData.output === "string") {
            outputItem = furnaceData.output;
        } else if (furnaceData.output?.item) {
            outputItem = furnaceData.output.item;
        }

        if (outputItem) {
            const recipePath = `/LunaTech_BP/recipes/smelting/${filePath.split("/").pop()}`;
            recipeData[recipePath] = recipeJson;

            if (!recipesByOutput[outputItem]) {
                recipesByOutput[outputItem] = [];
            }
            recipesByOutput[outputItem].push(recipePath);
        }
    }
}

function applyRecipesToItems<
    T extends { identifier: string; recipes: string[] },
>(items: T[]): T[] {
    return items.map((item) => {
        const recipes = recipesByOutput[item.identifier] || [];
        return { ...item, recipes };
    });
}

