---
import "../styles/global.css";
import Nav from "./navbar.astro";
import Head from "./head.astro";
import Footer from "./footer.astro";

interface Props {
    title: string;
    sidebarLinks?: Array<{ label: string; href: string }>;
}
const { title, sidebarLinks = [] } = Astro.props;
---

<html lang="en">
    <Head />
    <body>
        <Nav highlighted="navwiki" />
        <div class="wiki-container">
            <main class="wiki-content">
                <h1>{title}</h1>
                <slot />
            </main>
        </div>
        <Footer />
    </body>
</html>

<style>
    .wiki-container {
        margin: 2rem 5vw;
    }
    .wiki-content {
        background: #222;
        border: 1px solid #333;
        padding: 2rem;
    }
    .wiki-content h1 {
        color: #e1ff00;
        margin-top: 0;
        margin-bottom: 2rem;
    }
    @media (max-width: 768px) {
        .wiki-container {
            margin: 1rem 2vw;
        }
        .wiki-content {
            padding: 1rem;
        }
    }
</style>