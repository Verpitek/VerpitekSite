                href="https://discord.gg/fyNQNrr7dC"
                target="_blank"
                rel="noopener noreferrer"
                data-i18n="footer.discord">Discord Community</a
            >
        </nav>
        <div class="footer-divider"></div>
        <p><a class="footer-link" href="mailto:info@verpitek.com">info@verpitek.com</a> — <span data-i18n="footer.contact">commissions and inquiries</span></p>
