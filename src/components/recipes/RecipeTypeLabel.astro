---
import type { RecipeType } from "../../lib/recipes/types";

interface Props {
  type: RecipeType;
}

const { type } = Astro.props;

const labels: Record<RecipeType, string> = {
  shaped: "Shaped Crafting",
  shapeless: "Shapeless Crafting",
  furnace: "Smelting",
};

const colors: Record<RecipeType, string> = {
  shaped: "#8b4513",
  shapeless: "#556b2f",
  furnace: "#c0504d",
};
---

<div class="recipe-label" style={`background-color: ${colors[type]}`}>
  {labels[type]}
</div>

<style>
  .recipe-label {
    display: inline-block;
    padding: 4px 8px;

    font-size: 0.8rem;
    font-weight: bold;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
</style>
