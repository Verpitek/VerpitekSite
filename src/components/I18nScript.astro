---
import { translations } from "../lib/i18n";
---

<script define:vars={{ translations }}>
    function applyTranslations(lang) {
        const t = translations[lang] || translations["en"];
        document.querySelectorAll("[data-i18n]").forEach((el) => {
            const key = el.getAttribute("data-i18n");
            if (t[key]) {
                el.textContent = t[key];
            }
        });
        document.documentElement.lang = lang;
    }

    function initI18n() {
        const lang = localStorage.getItem("verpitek-lang") || "en";
        applyTranslations(lang);
        document.addEventListener("lang-change", (e) => {
            applyTranslations(e.detail.lang);
        });
    }

    initI18n();
    document.addEventListener("astro:after-swap", initI18n);
</script>
